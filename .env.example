# Backend API URL (for REST API endpoints)
# Video calls now use PeerJS (free signaling) - works on Vercel!
#
# Examples:
#   Production (Vercel):  https://mind-vista-backend.vercel.app
#   Local dev:            http://localhost:3000
#
VITE_API_URL=https://mind-vista-backend.vercel.app
