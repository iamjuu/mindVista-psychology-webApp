# ===========================================
# MindVista Frontend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Backend API URL (required for video calls to work)
# - Vercel backend: REST works, WebSocket does NOT - video calls will fail
# - Railway/Render: Both work - set this after deploying backend there
#
# Examples:
#   Production (Railway): https://mindvista-backend.railway.app
#   Production (Render):   https://mindvista-backend.onrender.com
#   Local dev:             http://localhost:3000
#
VITE_API_URL=https://mind-vista-backend.vercel.app

# WebSocket URL (optional - derived from VITE_API_URL if not set)
# Only needed if your WebSocket server is on a different host than the API
# Examples:
#   Same as API:  wss://mindvista-backend.railway.app
#   Local dev:   ws://localhost:3000
#
# VITE_WS_URL=wss://mind-vista-backend.vercel.app
